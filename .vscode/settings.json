{
	"eslint.useFlatConfig": true,
	"eslint.validate": [
		"javascript",
		"javascriptreact",
		"typescript",
		"typescriptreact",
		"svelte"
	],
	"eslint.workingDirectories": [{ "mode": "auto" }],
	"editor.codeActionsOnSave": {
		"source.fixAll.eslint": "explicit"
	},
	"eslint.options": {
		"overrideConfigFile": "eslint.config.js"
	}
}
