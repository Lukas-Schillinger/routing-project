{
	"permissions": {
		"allow": [
			"Edit",
			"Bash(grep:*)",
			"Bash(ls:*)",
			"Bash(cat:*)",
			"Bash(ls:*)",
			"Bash(cat:*)",
			"Bash(find:*)",
			"Bash(tree:*)",

			"Bash(git status:*)",
			"Bash(git diff:*)",
			"Bash(git log:*)",
			"Bash(git show:*)",
			"Bash(git branch:*)",
			"Bash(npm run check:*)",
			"Bash(npm run lint:*)",
			"Bash(npm run test:*)",
			"Bash(npm run test:unit:*)",

			"mcp__claude_ai_Notion__notion-search",
			"mcp__claude_ai_Notion__notion-fetch",
			"mcp__claude_ai_Notion__notion-update-page",
			"mcp__claude_ai_Notion__notion-create-pages",
			"mcp__claude_ai_Notion__notion-get-comments",
			"mcp__claude_ai_Notion__notion-create-comment",

			"mcp__plugin_svelte_svelte__svelte-autofixer",

			"Skill(frontend-design)",
			"Skill(notion-issues)",

			"WebFetch(domain:docs.stripe.com)",
			"WebFetch(domain:shadcn-svelte.com)",
			"WebFetch(domain:bits-ui.com)",
			"WebFetch(domain:www.npmjs.com)",
			"WebFetch(domain:raw.githubusercontent.com)",
			"WebFetch(domain:runed.dev)",
			"WebFetch(domain:superforms.rocks)",
			"WebFetch(domain:formsnap.dev)",
			"WebFetch(domain:vitest.dev)",
			"WebFetch(domain:shaders.paper.design)"
		]
	},
	"enabledPlugins": {
		"typescript-lsp@claude-plugins-official": true,
		"linear@claude-plugins-official": true
	},
	"hooks": {
		"WorktreeCreate": [
			{
				"hooks": [
					{
						"type": "command",
						"command": ".claude/hooks/setup-worktree.sh"
					}
				]
			}
		],
		"WorktreeRemove": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "bash -c 'jq -r .worktree_path | xargs git worktree remove --force'"
					}
				]
			}
		]
	}
}
